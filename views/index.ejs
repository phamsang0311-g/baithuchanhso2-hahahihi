<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Happy Blog 🌈</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <header class="blog-header text-center py-4">
        <h1 class="blog-title">🌈 My Happy Blog 🦄</h1>
        <p class="header-subtitle">Nơi lưu giữ kỷ niệm phiên bản MVC ✨</p>
    </header>

    <div class="container-fluid px-5">
        <div class="row g-5">
            <div class="col-lg-4">
                <div class="card create-post-card p-5 border-0 shadow-sm">
                    <h4 class="card-title-lg mb-4">Tạo niềm vui mới ✍️</h4>
                    <form action="/posts/store" method="POST">
                        <input type="text" name="title" class="form-control custom-input mb-3" placeholder="Tiêu đề..." required>
                        <textarea name="content" class="form-control custom-input mb-4" rows="6" placeholder="Kể chuyện đi nào..." required></textarea>
                        <button type="submit" class="btn btn-post w-100 py-3">ĐĂNG BÀI NGAY</button>
                    </form>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="search-bar-container mb-4">
                    <div class="search-box-wrapper">
                        <i class="fa-solid fa-magnifying-glass search-icon"></i>
                        <input type="text" id="searchInput" placeholder="Tìm kiếm kỷ niệm của bạn...">
                    </div>
                </div>

                <div class="section-title-wrapper mb-4">
                    <h3 class="post-list-heading">Góc kỷ niệm ✨</h3>
                    <div class="accent-line"></div>
                </div>
                
                <div id="post-list">
                    <% posts.forEach(post => { %>
                        <div class="card post-card-item mb-4 p-4 border-0 shadow-sm">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h5 class="fw-bold mb-1 text-dark" style="font-size: 1.4rem;"><%= post.title %></h5>
                                    <small class="text-secondary">
                                        <i class="fa-regular fa-calendar-days"></i> 
                                        <%= post.createdAt.toLocaleDateString('vi-VN') %>
                                    </small>
                                </div>
                                
                                <div class="action-buttons d-flex gap-2">
                                    <a href="/posts/edit/<%= post._id %>" class="btn btn-outline-primary btn-sm border-0 shadow-none">
                                        <i class="fa-solid fa-pen-to-square" style="font-size: 1.3rem;"></i>
                                    </a>
                                    <form action="/posts/delete/<%= post._id %>?_method=DELETE" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger btn-sm border-0 shadow-none" onclick="return confirm('Xóa bài này nhé?')">
                                            <i class="fa-solid fa-trash-can" style="font-size: 1.3rem;"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <p class="text-muted mb-0" style="font-size: 1.1rem;"><%= post.content %></p>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>

    <div class="decoration-container">
        <div class="pencil-wrapper">
            <img src="/images/butchi.png" class="soft-img" alt="Bút chì">
        </div>
        <div class="anime-wrapper">
            <img src="/images/anime-squad.png" class="soft-img" alt="Anime Squad">
        </div>
    </div>

    <script>
        // Chức năng tìm kiếm nhanh
        document.getElementById('searchInput').addEventListener('keyup', function() {
            let filter = this.value.toLowerCase();
            document.querySelectorAll('.post-card-item').forEach(card => {
                let text = card.innerText.toLowerCase();
                card.style.display = text.includes(filter) ? "block" : "none";
            });
        });
    </script>
</body>
</html>