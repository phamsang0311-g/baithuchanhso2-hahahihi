<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Chỉnh sửa kỷ niệm ✨</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body style="background-color: #f0f7ff;">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card p-5 shadow-sm" style="border-radius: 40px; border: none;">
                    <h3 class="fw-bold mb-4">Chỉnh sửa kỷ niệm ✍️</h3>
                    <form action="/posts/update/<%= post._id %>?_method=PUT" method="POST">
                        <input type="text" name="title" class="form-control custom-input mb-3 p-3" value="<%= post.title %>" required>
                        <textarea name="content" class="form-control custom-input mb-4 p-3" rows="7" required><%= post.content %></textarea>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-post flex-grow-1">LƯU THAY ĐỔI</button>
                            <a href="/" class="btn btn-light border p-3" style="border-radius: 20px; font-weight: 700;">HỦY</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>